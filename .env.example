# ── API Keys ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ── LangSmith tracing (smith.langchain.com → Settings → API Keys) ─────────
# All LangGraph invocations are traced automatically when these are set.
# Each agent node (@traceable) appears as a child span in the LangSmith UI.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-key-here
LANGCHAIN_PROJECT=cae-nvh-platform
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Weights & Biases (wandb.ai → Settings → API Keys) ─────────────────────
# Used during surrogate model training to log RMSE, R², and CV scores.
# Run: wandb login  (once), then train: python tools/surrogate_model.py
WANDB_API_KEY=your-wandb-key-here
WANDB_PROJECT=cae-surrogate-models
WANDB_ENTITY=your-wandb-username

# ── API Authentication ────────────────────────────────────────────────────
# Protects /invoke, /diagnose, /predict endpoints with X-API-Key header.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable auth (local dev only).
CAE_API_KEY=

# ── App settings ──────────────────────────────────────────────────────────
VECTOR_STORE_PATH=./data/faiss_index
CHROMA_PATH=./data/chroma_db
SYNTHETIC_DATA_PATH=./data/synthetic
LOG_LEVEL=INFO

# ── Remote deployment ─────────────────────────────────────────────────────
# Set HOST/PORT when running in Docker or on a remote server
HOST=0.0.0.0
PORT=8000
